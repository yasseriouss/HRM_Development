{
  "compilerOptions": {
    "target": "ESNext",
    "useDefineForClassFields": true,
    "lib": ["DOM", "DOM.Iterable", "ESNext"],
    "allowJs": false,
    "skipLibCheck": true,
    "esModuleInterop": false,
    "allowSyntheticDefaultImports": true,
    "strict": false,
    "noImplicitAny": false,
    "forceConsistentCasingInFileNames": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "types": ["vite/client"],
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@/lib/*": ["src/shared/lib/*"],
      "@/components/*": ["src/shared/components/*"],
      "@/hooks/*": ["src/shared/hooks/*"],
      "@shared/*": ["src/shared/*"],
      "@modules/*": ["src/modules/*"],
      "@hrm-development/api-client-react": ["lib/api-client-react/src/index.ts"],
      "@hrm-development/api-zod": ["lib/api-zod/src/index.ts"],
      "@hrm-development/db": ["lib/db/src/index.ts"],
      "@hrm-development/db/drizzle": ["lib/db/src/drizzle.ts"],
      "@hrm-development/db/schema": ["lib/db/src/schema/index.ts"]
    }
  },
  "include": ["src", "api", "index.ts", "server/src"],
  "exclude": ["node_modules", "dist"],
  "references": [
    { "path": "./lib/db" },
    { "path": "./lib/api-client-react" },
    { "path": "./lib/api-zod" }
  ]
}
