{
  "name": "@hrm-development/api-server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "BASE_PATH=/ebdaa-dashboard/ pnpm --filter @hrm-development/ebdaa-dashboard run build && export NODE_ENV=development && pnpm run build && pnpm run start",
    "build": "node ./build.mjs",
    "start": "node --enable-source-maps ./dist/index.mjs",
    "typecheck": "tsc -p tsconfig.check.json",
    "seed:build": "node ./seed-build.mjs",
    "seed": "pnpm run seed:build && node ./dist/seed.mjs"
  },
  "dependencies": {
    "@hrm-development/api-zod": "workspace:*",
    "@hrm-development/db": "workspace:*",
    "@vercel/speed-insights": "^2.0.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2",
    "drizzle-orm": "catalog:",
    "express": "^5",
    "pino": "^9",
    "pino-http": "^10"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "catalog:",
    "esbuild": "^0.27.3",
    "esbuild-plugin-pino": "^2.3.3",
    "pino-pretty": "^13",
    "thread-stream": "3.1.0"
  }
}
