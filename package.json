{
  "name": "hrm-development",
  "version": "0.0.0",
  "main": "src/index.ts",
  "type": "module",
  "license": "MIT",
  "scripts": {
    "preinstall": "node -e \"if (!process.env.npm_config_user_agent.startsWith('pnpm/')) { console.error('Use pnpm instead'); process.exit(1); }\"",
    "build": "pnpm run typecheck && pnpm -r --if-present run build",
    "vercel-build": "pnpm run build",
    "typecheck:libs": "tsc --build",
    "typecheck": "pnpm run typecheck:libs && pnpm -r --filter \"./artifacts/**\" --filter \"./scripts\" --if-present run typecheck",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "private": true,
  "dependencies": {
    "@neondatabase/serverless": "^1.1.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "drizzle-orm": "^0.45.2",
    "express": "^5.0.0",
    "pg": "^8.20.0",
    "pino": "^9.6.0",
    "pino-http": "^10.4.0"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "jsdom": "^29.1.1",
    "prettier": "^3.8.1",
    "typescript": "~5.9.2",
    "vitest": "^4.1.5"
  },
  "pnpm": {
    "overrides": {
      "micromatch>picomatch": "2.3.2",
      "vite>picomatch": "4.0.4",
      "path-to-regexp": "8.4.2",
      "lodash": "4.18.1",
      "yaml": "2.8.4",
      "minimatch>brace-expansion": "2.1.0",
      "postcss": "8.5.13",
      "uuid": "9.0.1"
    }
  }
}
