{
  "name": "@hrm-development/api-server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch --env-file=.env src/index.ts",
    "build": "node ./build.mjs",
    "start": "node --enable-source-maps ./dist/index.mjs",
    "typecheck": "tsc -p tsconfig.check.json",
    "seed:build": "node ./seed-build.mjs",
    "seed": "pnpm run seed:build && node --env-file=.env ./dist/seed.mjs"
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.1.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2",
    "express": "^5",
    "pg": "^8.20.0",
    "pino": "^9",
    "pino-http": "^10"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "catalog:",
    "esbuild": "^0.27.3",
    "esbuild-plugin-pino": "^2.3.3",
    "pino-pretty": "^13",
    "thread-stream": "3.1.0",
    "tsx": "catalog:",
    "vite": "catalog:"
  }
}
