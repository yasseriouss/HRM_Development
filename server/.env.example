# Loaded by: pnpm --filter @hrm-development/api-server run dev
# Path is relative to the server package — keep this file as server/.env

PORT=8080

# Neon (host contains neon.tech) uses the Neon HTTP driver automatically.
# Local Docker / RDS / etc. use the node-postgres (TCP) driver automatically.
# Optional: HRM_DB_DRIVER=neon | postgres
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require
