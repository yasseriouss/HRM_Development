# Loaded by: pnpm --filter @hrm-development/api-server run dev
# Path is relative to the server package — keep this file as server/.env

PORT=8080

# Neon (host contains neon.tech):
# - On Vercel (VERCEL=1 / VERCEL_ENV): uses the Neon **HTTP** driver; non-pooled `ep-…` URLs are
#   rewritten to **pooled** `ep-…-pooler…` unless HRM_NEON_USE_POOLER=0.
# - Elsewhere (local `pnpm dev`, long-lived Node): uses **node-postgres (TCP)** — same DATABASE_URL,
#   better TLS/proxy compatibility than the HTTP driver.
# Optional: HRM_DB_DRIVER=neon (force HTTP) | postgres (force TCP)
# Optional: HRM_PG_CONNECT_TIMEOUT_MS=15000
# Optional: HRM_EXPOSE_AUTH_ERRORS=1 — on Vercel (NODE_ENV=production), include `message` in JSON for
# /api/auth/* 500 responses so you can see the real DB error in the browser network tab. Remove after debugging.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require
