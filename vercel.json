{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "buildCommand": "pnpm run vercel-build",
  "outputDirectory": "dist",
  "installCommand": "pnpm install --frozen-lockfile=false",
  "framework": null,
  "functions": {
    "api/index.ts": {
      "memory": 1024,
      "maxDuration": 30,
      "includeFiles": "server/**"
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index.ts" },
    { "source": "/healthz", "destination": "/api/index.ts" },
    { "source": "/hrm-skill-matrix-template.xlsx", "destination": "/api/index.ts" },

    { "source": "/skill-matrix/:path*", "destination": "/index.html" },
    { "source": "/job-evaluation/:path*", "destination": "/index.html" },
    { "source": "/spreadsheet/:path*", "destination": "/index.html" },
    { "source": "/docs/:path*", "destination": "/index.html" },
    { "source": "/interactive-presentation/:path*", "destination": "/index.html" },
    { "source": "/my-profile/:path*", "destination": "/index.html" },
    { "source": "/login", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(.*)\\.(?:js|mjs|css|woff2?|ttf|otf|jpg|jpeg|png|gif|svg|webp|ico|map)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(.*)\\.html",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    },
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, max-age=0" },
        { "key": "X-Content-Type-Options", "value": "nosniff" }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" }
      ]
    }
  ],
  "regions": ["fra1"],
  "trailingSlash": false,
  "cleanUrls": false
}
