{
  "version": 2,
  "functions": {
    "src/index.ts": {
      "includeFiles": "artifacts/**",
      "memory": 1024,
      "maxDuration": 30
    }
  },
  "env": {
    "DATABASE_URL": "@hrmdev_database_url",
    "OPENROUTER_API_KEY": "@openrouter_api_key"
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/src/index.ts"
    },
    {
      "source": "/hrm-skill-matrix/(.*)",
      "destination": "/src/index.ts"
    },
    {
      "source": "/hrm-dashboard/(.*)",
      "destination": "/src/index.ts"
    },
    {
      "source": "/hrm-docs/(.*)",
      "destination": "/src/index.ts"
    },
    {
      "source": "/hrm-pitch-deck/(.*)",
      "destination": "/src/index.ts"
    },
    {
      "source": "/hrm-spreadsheet/(.*)",
      "destination": "/src/index.ts"
    },
    {
      "source": "/hrm-skill-matrix-template.xlsx",
      "destination": "/src/index.ts"
    }
  ]
}
